  {
    "id": "TC003",
    "title": "No-results empty state and Clear Filters restores results",
    "description": "Verifies empty state appears when filters return no matches and Clear Filters restores product results.",
    "category": "Product Listing & Discovery",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /products"
      },
      {
        "type": "action",
        "description": "Wait for element \"Product\" is visible"
      },
      {
        "type": "action",
        "description": "Select a Category filter that is likely to narrow results significantly"
      },
      {
        "type": "action",
        "description": "Select a Brand filter that is likely to conflict with the selected Category"
      },
      {
        "type": "assertion",
        "description": "Verify text \"No products\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Clear Filters\" is visible"
      },
      {
        "type": "action",
        "description": "Click on \"Clear Filters\""
      },
      {
        "type": "assertion",
        "description": "Verify element \"Product\" is visible"
      }
    ]
  },
