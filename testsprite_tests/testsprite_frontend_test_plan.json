  {
    "id": "TC001",
    "title": "Filter by category + price range, switch to List view, and open a product detail",
    "description": "Verifies users can browse products, apply category and price filters, change view mode, and navigate to a product detail page.",
    "category": "Product Listing & Discovery",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /products"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Loading\" is visible"
      },
      {
        "type": "action",
        "description": "Wait for element \"Product\" is visible"
      },
      {
        "type": "action",
        "description": "Click on category filter \"Women's Fashion\""
      },
      {
        "type": "action",
        "description": "Set the price range minimum to \"0\""
      },
      {
        "type": "action",
        "description": "Set the price range maximum to \"150\""
      },
      {
        "type": "action",
        "description": "Click on \"List\" view toggle"
      },
      {
        "type": "action",
        "description": "Click on the first visible product item"
      }
    ]
  },
