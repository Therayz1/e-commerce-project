  {
    "id": "TC017",
    "title": "Complete checkout from cart through confirmation and verify cart is emptied",
    "description": "Verifies the end-to-end checkout flow (shipping → payment → review → place order) and that the cart is cleared after confirmation.",
    "category": "Checkout Process",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /cart"
      },
      {
        "type": "action",
        "description": "Click on \"Proceed to Checkout\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/checkout\""
      },
      {
        "type": "action",
        "description": "Fill shipping information"
      },
      {
        "type": "action",
        "description": "Click \"Continue to Payment\""
      },
      {
        "type": "action",
        "description": "Fill mock payment details"
      },
      {
        "type": "action",
        "description": "Click \"Review Order\""
      },
      {
        "type": "action",
        "description": "Click \"Place Order\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Processing...\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Order\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Order Number\" is visible"
      },
      {
        "type": "action",
        "description": "Navigate to /cart"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Your cart is empty\" is visible"
      }
    ]
  },
